# Build directories
/build/
/cmake-build-*/

# CMake and Ninja generated files
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/compile_commands.json
/CTestTestfile.cmake
/Testing/
/build.ninja
/.ninja_deps
/.ninja_log

# Local tool caches
/.cache/

# Editor / OS files
/.idea/
/.vscode/
.DS_Store

# Visual Studio Code Extensions
node_modules/
out/

# NuGet package build artifacts (assembled by CI before dotnet pack)
/nuget/runtimes/
/nuget/artifacts/
*.nupkg
*.snupkg
**/obj/
**/bin/

# Unity native plugin binaries (built by CI; only .meta files are committed)
unity/com.zscript.runtime/Plugins/**/*.dll
unity/com.zscript.runtime/Plugins/**/*.so
unity/com.zscript.runtime/Plugins/**/*.dylib
unity/com.zscript.runtime/Plugins/**/*.bundle
unity/com.zscript.runtime/Plugins/**/*.a

# Unity project generated folders (and any meta files inside them)
unity/UnityProject/Library/
unity/UnityProject/Temp/
unity/UnityProject/obj/
unity/UnityProject/Logs/
unity/UnityProject/UserSettings/
unity/UnityProject/Recordings/
unity/UnityProject/MemoryCaptures/

# Documentation vault local metadata
documentation/**/.makemd/
documentation/**/.space/
documentation/.obsidian/*
!documentation/.obsidian/app.json
!documentation/.obsidian/appearance.json
!documentation/.obsidian/community-plugins.json
!documentation/.obsidian/core-plugins.json
!documentation/.obsidian/graph.json
documentation-internal/**/.makemd/
documentation-internal/**/.space/
documentation-internal/.obsidian/*
!documentation-internal/.obsidian/app.json
!documentation-internal/.obsidian/appearance.json
!documentation-internal/.obsidian/community-plugins.json
!documentation-internal/.obsidian/core-plugins.json
!documentation-internal/.obsidian/graph.json
