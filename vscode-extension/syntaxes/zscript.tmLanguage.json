{
  "name": "ZScript",
  "scopeName": "source.zscript",
  "fileTypes": ["zs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#literals" },
    { "include": "#type-names" },
    { "include": "#class-decl" },
    { "include": "#trait-impl-decl" },
    { "include": "#fn-decl" },
    { "include": "#class-constructor" },
    { "include": "#fn-call" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.zscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.zscript",
          "begin": "@[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*",
          "end": "(?=\\s|\\{|$)",
          "beginCaptures": {
            "0": { "name": "storage.modifier.annotation.zscript" }
          },
          "patterns": [
            {
              "name": "meta.annotation.arguments.zscript",
              "begin": "\\(",
              "end": "\\)",
              "patterns": [
                { "include": "#strings" },
                { "include": "#literals" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.zscript",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.embedded.line.zscript",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.zscript" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.template-expression.end.zscript" } },
          "patterns": [{ "include": "$self" }]
        },
        {
          "name": "constant.character.escape.zscript",
          "match": "\\\\[nrtv\\\\\"'0]"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zscript",
          "match": "\\b(if|else|while|for|in|return|break|continue|not|match|throw|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.zscript",
          "match": "\\b(fn|class|trait|impl|var|let|import|prop|mut)\\b"
        },
        {
          "name": "keyword.operator.logical.zscript",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "variable.language.zscript",
          "match": "\\bself\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.zscript",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "constant.numeric.float.zscript",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.zscript",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "type-names": {
      "patterns": [
        {
          "comment": "Highlight built-in and common type names",
          "name": "support.type.zscript",
          "match": "\\b(Int|Float|Bool|String|Void|Any|nil|Vec2|Vec3|Vec4|Quat|Transform|Actor|ActorComponent|MonoBehaviour|List|Map|Fn)\\b"
        }
      ]
    },
    "class-decl": {
      "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.declaration.zscript" },
        "2": { "name": "entity.name.type.class.zscript" },
        "3": { "name": "punctuation.separator.inheritance.zscript" },
        "4": { "name": "entity.other.inherited-class.zscript" }
      }
    },
    "trait-impl-decl": {
      "patterns": [
        {
          "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.zscript" },
            "2": { "name": "entity.name.type.trait.zscript" }
          }
        },
        {
          "match": "\\b(impl)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.zscript" },
            "2": { "name": "entity.name.type.trait.zscript" },
            "3": { "name": "keyword.control.zscript" },
            "4": { "name": "entity.name.type.class.zscript" }
          }
        }
      ]
    },
    "fn-decl": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.zscript" },
        "2": { "name": "entity.name.function.zscript" }
      }
    },
    "class-constructor": {
      "comment": "PascalCase identifier followed by ( — treated as constructor call",
      "match": "\\b([A-Z][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.type.class.zscript" }
      }
    },
    "fn-call": {
      "comment": "Function call sites — lowercase/underscore identifier immediately followed by (",
      "match": "\\b([a-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.zscript" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.null-safety.zscript",
          "match": "\\?\\.|!\\."
        },
        {
          "name": "keyword.operator.range.zscript",
          "match": "\\.\\.<|\\.\\."
        },
        {
          "name": "keyword.operator.arrow.zscript",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.assignment.zscript",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.comparison.zscript",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.zscript",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.zscript",
          "match": "\\*\\*|[+\\-*/%]"
        },
        {
          "name": "keyword.operator.nil-coalescing.zscript",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.nullable.zscript",
          "match": "\\?"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "PascalCase identifiers are likely type/class names",
          "name": "entity.name.type.zscript",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.zscript",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
