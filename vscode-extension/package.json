{
  "name": "zscript",
  "displayName": "ZScript",
  "description": "ZScript language support: syntax highlighting, diagnostics, completion, hover, go-to-definition, signature help",
  "version": "0.2.0",
  "publisher": "zscript",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Debuggers"],
  "activationEvents": [
    "onLanguage:zscript",
    "onCommand:zscript.showStatus",
    "onCommand:zscript.showServerPath",
    "onCommand:zscript.showOutput",
    "onCommand:zscript.restartServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "zscript",
        "aliases": ["ZScript", "zscript"],
        "extensions": [".zs"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zscript",
        "scopeName": "source.zscript",
        "path": "./syntaxes/zscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "zscript.restartServer",
        "title": "ZScript: Restart Language Server"
      },
      {
        "command": "zscript.showServerPath",
        "title": "ZScript: Show Server Path"
      },
      {
        "command": "zscript.showOutput",
        "title": "ZScript: Show Language Server Output"
      },
      {
        "command": "zscript.showStatus",
        "title": "ZScript: Show Language Server Status"
      }
    ],
    "debuggers": [
      {
        "type": "zscript",
        "label": "ZScript Debug",
        "languages": ["zscript"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .zs file to debug."
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause on the first line.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "zscript",
            "request": "launch",
            "name": "Debug ZScript",
            "program": "${file}",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "configuration": {
      "title": "ZScript",
      "properties": {
        "zscript.serverPath": {
          "type": "string",
          "default": "zsc",
          "description": "Path to the zsc binary. Leave as 'zsc' to auto-detect from workspace build folders or PATH."
        },
        "zscript.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the ZScript language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:server": "cmake -S .. -B ../build && cmake --build ../build --target zsc",
    "build": "npm run build:server && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
